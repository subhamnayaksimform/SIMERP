# SIM ERP staging environment
BASE_URL=https://staging.simerp.example.com

# Anthropic API key — required for automated full-pipeline (npm run pipeline → option 0)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Zoho Projects API (OAuth2)
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here
ZOHO_PORTAL_ID=your_portal_id_here
ZOHO_PROJECT_ID=your_project_id_here
ZOHO_REGION=com

# Test credentials for SIM ERP (do NOT commit real values)
# Account 1 — Primary / Admin (direct credentials) → Playwright fixture: primaryPage → storageState.json
SIMERP_USERNAME=primary.admin@example.com
SIMERP_PASSWORD=changeme

# Account 2 — Test user (TM / Employee, direct credentials) → Playwright fixture: testUserPage → storageState-punit.json
SIMERP_TEST_USERNAME=test.user@example.com
SIMERP_TEST_PASSWORD=changeme
