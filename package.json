{
  "name": "simerp-qa-ai-flow",
  "version": "1.0.0",
  "private": true,
  "description": "AI-driven QA automation flow for SIM ERP using VS Code agents & skills",
  "scripts": {
    "test": "playwright test --config=tests/playwright.config.ts --project=chromium",
    "test:headed": "playwright test --config=tests/playwright.config.ts --project=chromium --headed",
    "test:cross-browser": "playwright test --config=tests/playwright.config.ts",
    "test:report": "playwright show-report reports/results/html",
    "pipeline": "ts-node scripts/pipeline.ts",
    "report:excel": "ts-node .claude/skills/excel-reporter/scripts/generate-excel.ts",
    "kb:update": "ts-node scripts/update-knowledge-base.ts",
    "lint:tests": "ts-node scripts/lint-test-conventions.ts",
    "lint:tests:baseline": "ts-node scripts/lint-test-conventions.ts --update-baseline",
    "extract:selectors": "ts-node scripts/extract-selector-inventory.ts",
    "report:coverage": "ts-node scripts/coverage-report.ts",
    "review:cases": "ts-node scripts/test-case-review.ts"
  },
  "devDependencies": {
    "@clack/prompts": "^1.5.1",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "axios": "^1.7.0",
    "caveman": "^0.1.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "zod": "^3.25.76"
  }
}
